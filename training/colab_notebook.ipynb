   "source": [
    "# Role Drift Env - Colab Smoke Test\n",
    "\n",
    "This notebook validates that the training pipeline runs end-to-end on a free Colab T4.\n",
    "Full 100+ ep training requires paid compute; this proves the pipeline works."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install deps\n",
    "!pip install -q openenv-core sentence-transformers torch"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Clone repo\n",
    "!git clone https://github.com/anomalyco/role-drift-env.git /content/role-drift-env\n",
    "%cd /content/role-drift-env"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Smoke test: load env\n",
    "from role_drift_env.server.environment import RoleDriftEnvironment\n",
    "env = RoleDriftEnvironment()\n",
    "obs, state = env.reset(\"term_kk_01\", 0)\n",
    "print(f\"Loaded: {len(obs.system_prompt)} chars prompt\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Smoke test: detectors\n",
    "from role_drift_env.server.rewards import RewardComposer\n",
    "from role_drift_env.models import AgentAction\n",
    "\n",
    "composer = RewardComposer()\n",
    "action = AgentAction(utterance=\"I am an AI assistant\")\n",
    "reward = composer.score(state, action)\n",
    "print(f\"Penalty for 'I am an AI': {reward.total}\")\n",
    "print(\"Detectors work!\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Next Steps\n",
    "\n",
    "1. Start vLLM server for customer sim: `python -m vllm.entrypoints.openai.api_server --model Qwen/Qwen2.5-7B-Instruct`\n",
    "2. Run full training: `python training/train_grpo.py --episodes 150 --group_size 4`\n",
    "3. Evaluate: `python training/eval_baseline.py`"
   ]
  },
  {
